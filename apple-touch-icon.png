<svg xmlns="http://www.w3.org/2000/svg" width="180" height="180" viewBox="0 0 180 180" role="img" aria-label="Apple Touch Icon">
  <defs>
    <radialGradient id="bg" cx="0.3" cy="0.3" r="0.9">
      <stop offset="0" stop-color="#5fa538"/>
      <stop offset="1" stop-color="#589632"/>
    </radialGradient>
  </defs>
  <!-- Rounded square background -->
  <rect x="0" y="0" width="180" height="180" rx="36" fill="url(#bg)"/>

  <!-- White Q ring -->
  <circle cx="90" cy="90" r="40" fill="none" stroke="#ffffff" stroke-width="14" stroke-linecap="round" />
  <!-- Q tail -->
  <path d="M118 118 L138 138" stroke="#ffffff" stroke-width="14" stroke-linecap="round" />

  <!-- Accent pin dot -->
  <circle cx="135" cy="52" r="10" fill="#F0A202" />
</svg>
